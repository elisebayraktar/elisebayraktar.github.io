---
import { Moon, Sun } from '@lucide/astro'
---

<button
  class="relative inline-flex size-9 items-center justify-center rounded-md border bg-background transition-colors hover:bg-accent hover:text-accent-foreground"
  data-theme-toggle
  type="button"
>
  <Sun class="h-[1.2rem] w-[1.2rem] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
  <Moon class="absolute h-[1.2rem] w-[1.2rem] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
  <span class="sr-only">Toggle theme</span>
</button>

<script>
  const STORAGE_KEY = 'vite-ui-theme'

  const toggleTheme = () => {
    const root = document.documentElement
    const next = root.classList.contains('dark') ? 'light' : 'dark'
    root.classList.remove('light', 'dark')
    root.classList.add(next)
    localStorage.setItem(STORAGE_KEY, next)
  }

  document.querySelector('[data-theme-toggle]')?.addEventListener('click', toggleTheme)
</script>
