---
import Header from "@/components/header.astro";
import AboutMe from "@/components/sections/about-me.astro";
import Education from "@/components/sections/education.astro";
import Publications from "@/components/sections/publications.astro";
import Talks from "@/components/sections/talks.astro";
import Teachings from "@/components/sections/teachings.astro";
import Separator from "@/components/ui/separator.astro";
import Layout from "@/layouts/layout.astro";
import { sections, type SectionSlug } from "@/lib/constants";
import { cn } from "@/lib/utils";

const sectionContent: Record<SectionSlug, typeof AboutMe> = {
    "about-me": AboutMe,
    publications: Publications,
    talks: Talks,
    education: Education,
    teaching: Teachings,
};
---

<Layout>
    <div class="flex flex-col items-center">
        <Header />
        <main class="flex w-full flex-col items-center pt-8">
            {
                sections.map(({ slug, title }, index) => {
                    const Content = sectionContent[slug];
                    return (
                        <section
                            class={cn("flex w-full scroll-mt-20 flex-col items-center border-b bg-background py-20", {
                                "bg-card": index % 2 !== 0,
                            })}
                            id={slug}
                        >
                            <div class="container w-full px-8 md:px-20">
                                {slug !== "about-me" && (
                                    <>
                                        <h2 class="text-4xl font-extrabold uppercase">{title}</h2>
                                        <Separator class="my-4 mb-10 max-w-10" />
                                    </>
                                )}
                                <Content />
                            </div>
                        </section>
                    );
                })
            }
        </main>
    </div>
</Layout>
