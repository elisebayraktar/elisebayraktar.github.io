---
import Layout from '@/layouts/Layout.astro'
import Header from '@/components/Header.astro'
import AboutMe from '@/components/sections/about-me'
import Publications from '@/components/sections/publications'
import Talks from '@/components/sections/talks'
import Education from '@/components/sections/education'
import Teachings from '@/components/sections/teachings'
import { Separator } from '@/components/ui/separator'
import { sections } from '@/lib/constants'
import { cn } from '@/lib/utils'

const sectionContent = {
  'about-me': AboutMe,
  publications: Publications,
  talks: Talks,
  education: Education,
  teaching: Teachings,
} as const
---

<Layout>
  <div class="flex flex-col items-center">
    <Header />
    <main class="flex w-full flex-col items-center pt-8">
      {
        sections.map(({ slug, title }, index) => {
          const Content = sectionContent[slug as keyof typeof sectionContent]
          return (
            <section
              class={cn('flex scroll-mt-20 flex-col items-center bg-background w-full border-b py-20', {
                'bg-card': index % 2 !== 0,
              })}
              id={slug}
            >
              <div class="container w-full px-8 md:px-20">
                {slug !== 'about-me' && (
                  <>
                    <h2 class="text-4xl font-extrabold uppercase">{title}</h2>
                    <Separator className="my-4 mb-10 max-w-10" />
                  </>
                )}
                <Content />
              </div>
            </section>
          )
        })
      }
    </main>
  </div>
</Layout>
