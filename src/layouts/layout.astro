---
import '@/index.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="/favicon.ico" rel="icon" sizes="32x32" />
    <link as="font" crossorigin href="/fonts/raleway-400.woff2" rel="preload" type="font/woff2" />
    <link as="font" crossorigin href="/fonts/raleway-600.woff2" rel="preload" type="font/woff2" />
    <link as="font" crossorigin href="/fonts/raleway-800.woff2" rel="preload" type="font/woff2" />
    <link href="https://elisebayraktar.github.io/" rel="canonical" />
    <title>Elise Bayraktar - Probability & Statistics Researcher in Probability & Statistics</title>
    <meta
      content="Postdoctoral researcher at Sorbonne Université (LPSM) working with Charlotte Dion-Blanc on stochastic processes and statistical estimation."
      name="description"
    />
    <meta content="Tks34USbwbkthTI4YUeFquolMiSSuGZL_K057-TlIe8" name="google-site-verification" />
    <meta content="profile" property="og:type" />
    <meta content="https://elisebayraktar.github.io/" property="og:url" />
    <meta content="Elise Bayraktar - Postdoctoral Researcher in Probability & Statistics" property="og:title" />
    <meta
      content="Postdoctoral researcher at Sorbonne Université (LPSM) working on stochastic processes and statistical estimation."
      property="og:description"
    />
    <meta content="https://elisebayraktar.github.io/images/profile-picture.webp" property="og:image" />
    <meta content="summary" name="twitter:card" />
    <meta content="Elise Bayraktar - Postdoctoral Researcher in Probability & Statistics" name="twitter:title" />
    <meta
      content="Postdoctoral researcher at Sorbonne Université (LPSM) working on stochastic processes and statistical estimation."
      name="twitter:description"
    />
    <meta content="https://elisebayraktar.github.io/images/profile-picture.webp" name="twitter:image" />

    <script
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        affiliation: {
          '@type': 'Organization',
          alternateName: 'Laboratoire de Probabilités, Statistiques et Modélisation',
          logo: 'https://elisebayraktar.github.io/images/lpsm.webp',
          name: 'LPSM',
          parentOrganization: {
            '@type': 'CollegeOrUniversity',
            name: 'Sorbonne Université',
            url: 'https://www.sorbonne-universite.fr/',
          },
          url: 'https://www.lpsm.paris/',
        },
        alumniOf: [
          { '@type': 'CollegeOrUniversity', name: 'University of Cambridge', url: 'https://www.cam.ac.uk/' },
          { '@type': 'CollegeOrUniversity', name: 'CentraleSupélec', url: 'https://www.centralesupelec.fr/' },
          { '@type': 'CollegeOrUniversity', name: 'Université Gustave Eiffel', url: 'https://www.univ-gustave-eiffel.fr/' },
        ],
        award: 'Marie-Jeanne Laurent-Duhamel prize 2026',
        colleague: ['https://perso.math.u-pem.fr/clement.emmanuelle/'],
        image: 'https://elisebayraktar.github.io/images/profile-picture.webp',
        jobTitle: 'Postdoctoral Researcher',
        knowsAbout: [
          'Stochastic processes',
          'Statistical estimation',
          'Cox-Ingersoll-Ross model',
          'Lévy processes',
          'High-frequency estimation',
          'Probability theory',
        ],
        name: 'Elise Bayraktar',
        sameAs: [
          'https://scholar.google.com/citations?user=OttA_dQAAAAJ',
          'https://www.linkedin.com/in/elise-bayraktar/',
          'https://www.lpsm.paris/en/users/bayraktar/index',
          'https://pagespro.univ-gustave-eiffel.fr/elise-bayraktar',
          'https://lama-umr8050.fr/membres/bayraktar.elise',
          'https://theses.hal.science/tel-05517419',
        ],
        url: 'https://elisebayraktar.github.io/',
      })}
      type="application/ld+json"
    />

    <script is:inline>
      ;(() => {
        const stored = localStorage.getItem('vite-ui-theme')
        const theme = stored ?? 'system'
        const resolved = theme === 'system' ? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : theme
        document.documentElement.classList.add(resolved)
      })()
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
