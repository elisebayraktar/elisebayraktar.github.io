{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/vite-react/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"]
}
